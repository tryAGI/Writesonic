<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
  </PropertyGroup>

  <PropertyGroup Label="Nuget">
    <Description>C# SDK for the Writesonic API -- AI content generation, ChatSonic chatbot, Photosonic image generation, and SEO tools.</Description>
    <PackageId>Writesonic</PackageId>
    <PackageTags>api;client;sdk;dotnet;openapi;writesonic;content-generation;chatbot;ai;autosdk</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.AI" Version="10.4.1" />
  </ItemGroup>

</Project>
